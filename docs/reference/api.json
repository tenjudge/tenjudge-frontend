{
  "openapi": "3.1.0",
  "info": {
    "title": "OpenAPI definition",
    "version": "v0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "Contest",
      "description": "比赛管理与报名接口"
    },
    {
      "name": "Auth",
      "description": "认证、登录与注册接口。所有响应都包在 Result 中：code 为 0 表示成功，非 0 表示业务失败。登录成功后，前端应使用返回的 tokenName 作为请求头名称、tokenValue 作为请求头值访问需要登录的接口。"
    },
    {
      "name": "Problem",
      "description": "题目管理与查询接口"
    },
    {
      "name": "Submit",
      "description": "提交与判题接口"
    }
  ],
  "paths": {
    "/problem": {
      "get": {
        "tags": [
          "Problem"
        ],
        "summary": "分页查询公开题目列表",
        "description": "分页查询 public 题目，按 problemId 升序排列。接口不要求登录，只返回 id、name、difficulty 摘要字段。",
        "operationId": "queryPage",
        "parameters": [
          {
            "name": "current",
            "in": "query",
            "description": "当前页码，从 1 开始",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页数量，最大 100",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultProblemPageVO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Problem"
        ],
        "summary": "更新题目",
        "description": "更新题目元数据和可选的题目 zip 包。若上传新文件，服务端会在更新过程中同步处理校验、对象存储切换和版本变更。",
        "operationId": "update",
        "parameters": [
          {
            "name": "problemUpdateRequest",
            "in": "query",
            "required": true,
            "schema": {
              "$ref": "#/components/schemas/ProblemUpdateRequest"
            }
          },
          {
            "name": "zipFile",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Problem"
        ],
        "summary": "创建题目",
        "description": "上传题目 zip 包并创建题目，服务端会校验题目文件结构、配置内容和相关业务约束。",
        "operationId": "create",
        "parameters": [
          {
            "name": "zipFile",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultCreateProblemVO"
                }
              }
            }
          }
        }
      }
    },
    "/contest": {
      "get": {
        "tags": [
          "Contest"
        ],
        "summary": "分页查询比赛列表",
        "description": "分页查询全部比赛，按比赛开始时间倒序排列。接口不要求登录；登录用户会额外返回当前页比赛的报名状态。",
        "operationId": "queryContestPage",
        "parameters": [
          {
            "name": "current",
            "in": "query",
            "description": "当前页码，从 1 开始",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "每页数量，最大 100",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 30
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultContestPageVO"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "Contest"
        ],
        "summary": "更新比赛",
        "description": "更新比赛元数据和比赛题目编排。contestProblems 采用全量覆盖策略，freezeTime 为空表示不封榜，penaltyPerWrong 允许为空且后端会按 0 处理。",
        "operationId": "updateContest",
        "requestBody": {
          "description": "更新比赛请求体",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateContestRequest"
              },
              "examples": {
                "更新比赛与题目编排示例": {
                  "description": "更新比赛与题目编排示例",
                  "value": {
                    "contestId": 2001,
                    "name": "TenJudge April Challenge Finals",
                    "startTime": "2026-05-01T13:00:00",
                    "endTime": "2026-05-01T18:00:00",
                    "freezeTime": "2026-05-01T17:00:00",
                    "penaltyPerWrong": 20,
                    "contestProblems": [
                      {
                        "problemId": 1001,
                        "problemIndex": "A"
                      },
                      {
                        "problemId": 1002,
                        "problemIndex": "B"
                      }
                    ]
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Contest"
        ],
        "summary": "新建比赛",
        "description": "创建比赛元数据，不包含比赛题目编排。时间使用 ISO 8601 格式 yyyy-MM-dd'T'HH:mm:ss，freezeTime 为空表示不封榜，penaltyPerWrong 允许为空且后端会按 0 处理。",
        "operationId": "createContest",
        "requestBody": {
          "description": "创建比赛请求体",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateContestRequest"
              },
              "examples": {
                "创建比赛示例": {
                  "description": "创建比赛示例",
                  "value": {
                    "name": "TenJudge April Challenge",
                    "startTime": "2026-05-01T13:00:00",
                    "endTime": "2026-05-01T18:00:00",
                    "freezeTime": "2026-05-01T17:00:00",
                    "penaltyPerWrong": 20
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultCreateContestVO"
                }
              }
            }
          }
        }
      }
    },
    "/submit/judge": {
      "post": {
        "tags": [
          "Submit"
        ],
        "summary": "提交代码测评",
        "description": "用户与 Agent 共用该接口。公开题可直接提交；私有题会额外校验比赛上下文、比赛时间和报名状态。 problemId、language、code、isAgent 为必填字段。",
        "operationId": "submitJudge",
        "requestBody": {
          "description": "测评提交请求体。前端可直接按字段说明与示例构造请求。",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/JudgeRequest"
              },
              "examples": {
                "公开题普通用户提交": {
                  "description": "公开题普通用户提交",
                  "value": {
                    "problemId": 1001,
                    "language": "cpp",
                    "code": "#include \u003Cbits/stdc++.h\u003E\nusing namespace std;\nint main() {\n    cout \u003C\u003C 0 \u003C\u003C '\\n';\n    return 0;\n}",
                    "isAgent": false
                  }
                },
                "比赛私有题提交": {
                  "description": "比赛私有题提交",
                  "value": {
                    "problemId": 1001,
                    "contestId": 2001,
                    "language": "python",
                    "code": "print(0)",
                    "isAgent": false
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultSubmitJudgeVO"
                }
              }
            }
          }
        }
      }
    },
    "/contest/register": {
      "post": {
        "tags": [
          "Contest"
        ],
        "summary": "报名比赛",
        "description": "用户通过当前登录态报名比赛，请求体只需传 contestId。只要比赛未结束即可报名，重复报名按幂等成功处理。",
        "operationId": "registerContest",
        "requestBody": {
          "description": "报名比赛请求体",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterContestRequest"
              },
              "examples": {
                "报名比赛示例": {
                  "description": "报名比赛示例",
                  "value": {
                    "contestId": 2001
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Contest"
        ],
        "summary": "取消比赛报名",
        "description": "用户通过当前登录态取消比赛报名，请求体只需传 contestId。比赛开始前允许取消，比赛开始后返回 CONTEST_CANCEL_REGISTER_FAILED，未报名时按幂等成功处理。",
        "operationId": "cancelRegisterContest",
        "requestBody": {
          "description": "取消比赛报名请求体",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CancelRegisterContestRequest"
              },
              "examples": {
                "取消比赛报名示例": {
                  "description": "取消比赛报名示例",
                  "value": {
                    "contestId": 2001
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "注册用户",
        "description": "创建新用户并返回用户 ID。role 只能是 user、admin、super_admin；普通用户注册 role=user 不需要登录。注册 admin 或 super_admin 时，必须携带当前超级管理员 token，否则返回 UNAUTHORIZED 或 FORBIDDEN。用户名必须以字母开头，长度 3-20，只允许字母、数字、下划线；密码长度 8-20；邮箱必须唯一且格式合法。常见业务失败码：USERNAME_INVALID、PASSWORD_INVALID、EMAIL_INVALID、ROLE_INVALID、USERNAME_ALREADY_EXISTS、EMAIL_ALREADY_EXISTS、UNAUTHORIZED、FORBIDDEN、REGISTER_FAILED。",
        "operationId": "registerUser",
        "parameters": [
          {
            "name": "tenjudge-token",
            "in": "header",
            "description": "仅注册 admin 或 super_admin 时需要。值为登录接口返回的 tokenValue。"
          }
        ],
        "requestBody": {
          "description": "注册请求体",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "examples": {
                "注册普通用户": {
                  "description": "注册普通用户",
                  "value": {
                    "username": "alice_oj",
                    "password": "plainPass123",
                    "role": "user",
                    "email": "alice@example.com"
                  }
                },
                "超级管理员创建管理员": {
                  "description": "请求头需携带 tenjudge-token: {tokenValue}",
                  "value": {
                    "username": "problem_admin",
                    "password": "plainPass123",
                    "role": "admin",
                    "email": "admin@example.com"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultRegisterVO"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "登录",
        "description": "使用用户名或邮箱登录，成功后返回 tokenName、tokenValue 和当前用户信息。后续需要登录的接口应在请求头中传入：{tokenName}: {tokenValue}。账号不存在、密码错误、account 或 password 为空时均返回 LOGIN_FAILED，不区分具体原因。",
        "operationId": "login",
        "requestBody": {
          "description": "登录请求体。account 可以是用户名或邮箱。",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "examples": {
                "用户名登录": {
                  "description": "用户名登录",
                  "value": {
                    "account": "alice_oj",
                    "password": "plainPass123"
                  }
                },
                "邮箱登录": {
                  "description": "邮箱登录",
                  "value": {
                    "account": "alice@example.com",
                    "password": "plainPass123"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultLoginVO"
                }
              }
            }
          }
        }
      }
    },
    "/problem/visibility": {
      "patch": {
        "tags": [
          "Problem"
        ],
        "summary": "修改题目可见性",
        "description": "超级管理员将题目可见性切换为 public 或 private。修改后会失效题目缓存，避免匿名访问权限读到旧值。",
        "operationId": "updateVisibility",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProblemVisibilityUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    },
    "/problem/{id}": {
      "get": {
        "tags": [
          "Problem"
        ],
        "summary": "按题目 ID 查询题目",
        "description": "通过题目 ID 直接查询题目详情。普通用户不能访问无权限的 private 题目，返回内容遵循当前用户可见性规则。",
        "operationId": "queryById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultProblemVO"
                }
              }
            }
          }
        }
      }
    },
    "/contest/{contestId}": {
      "get": {
        "tags": [
          "Contest"
        ],
        "summary": "查询比赛详情",
        "description": "根据比赛 ID 查询比赛元数据和题目列表。接口不要求登录；比赛开始前仅管理员/超级管理员可以查看，普通用户和游客会返回 CONTEST_NOT_STARTED。",
        "operationId": "queryContestDetail",
        "parameters": [
          {
            "name": "contestId",
            "in": "path",
            "description": "比赛 ID",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultContestDetailVO"
                }
              }
            }
          }
        }
      }
    },
    "/contest/{contestId}/problem/{index}": {
      "get": {
        "tags": [
          "Problem"
        ],
        "summary": "在比赛中按题号查询题目",
        "description": "通过比赛 ID 和比赛内题号查询题目详情。已报名且在比赛访问窗口内的用户可按比赛规则受限访问题目，部分字段会按权限隐藏。",
        "operationId": "queryInContest",
        "parameters": [
          {
            "name": "contestId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "index",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultProblemVO"
                }
              }
            }
          }
        }
      }
    },
    "/agent/problem/{id}": {
      "get": {
        "tags": [
          "Problem"
        ],
        "summary": "Agent 按题目 ID 查询题目",
        "description": "Agent 通过独立接口按题目 ID 查询题目详情，沿用当前登录态鉴权，但权限严格小于普通用户，不能借此绕过比赛中的 private 题访问限制。",
        "operationId": "queryByAgent",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultProblemVO"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "delete": {
        "tags": [
          "Auth"
        ],
        "summary": "登出",
        "description": "注销当前 token 对应的登录态。前端应携带登录接口返回的 token 请求头，默认请求头名称为 tenjudge-token。",
        "operationId": "logout",
        "parameters": [
          {
            "name": "tenjudge-token",
            "in": "header",
            "description": "登录接口返回的 tokenValue。若部署时修改了 tokenName，请以登录响应中的 tokenName 为准。",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ResultVoid"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProblemUpdateRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ResultVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "data": {

          }
        }
      },
      "ContestProblemDTO": {
        "type": "object",
        "description": "比赛题目编排项",
        "properties": {
          "problemId": {
            "type": "integer",
            "format": "int64",
            "description": "题目 ID。同一场比赛内必须唯一",
            "example": 1001
          },
          "problemIndex": {
            "type": "string",
            "description": "比赛题号标识。同一场比赛内必须唯一，长度不超过 10",
            "example": "A"
          }
        },
        "required": [
          "problemId",
          "problemIndex"
        ]
      },
      "UpdateContestRequest": {
        "type": "object",
        "description": "更新比赛请求",
        "properties": {
          "contestId": {
            "type": "integer",
            "format": "int64",
            "description": "待更新的比赛 ID",
            "example": 2001
          },
          "name": {
            "type": "string",
            "description": "比赛名称，去首尾空格后不能为空，长度不超过 50",
            "example": "TenJudge April Challenge Finals"
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "比赛开始时间，使用 ISO 8601 格式 yyyy-MM-dd'T'HH:mm:ss",
            "example": "2026-05-01T13:00:00"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "比赛结束时间，使用 ISO 8601 格式 yyyy-MM-dd'T'HH:mm:ss，必须晚于 startTime",
            "example": "2026-05-01T18:00:00"
          },
          "freezeTime": {
            "type": "string",
            "format": "date-time",
